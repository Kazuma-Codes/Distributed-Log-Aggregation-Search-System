<!-- 
Standalone S3 disk configuration for ClickHouse.
Detailed settings for optimal performance with S3-compatible storage (MinIO).
-->
<clickhouse>
  <storage_configuration>
    <disks>
      <s3_disk_template>
        <type>s3</type>
        <endpoint>http://minio:9000/logs-bucket/</endpoint>
        <access_key_id>minioadmin</access_key_id>
        <secret_access_key>minioadmin</secret_access_key>
        
        <!-- Max single part size for multipart upload (50 MB) -->
        <s3_max_single_part_upload_size>52428800</s3_max_single_part_upload_size>
        
        <!-- Size of a part in multipart upload (5 MB) -->
        <s3_upload_part_size_multiply_factor>2</s3_upload_part_size_multiply_factor>
        
        <!-- Threads for parallel reading and writing -->
        <thread_pool_size>16</thread_pool_size>
        
        <!-- Max connections per endpoint -->
        <s3_max_connections>100</s3_max_connections>
        
        <!-- Send metadata indicating the file content type -->
        <send_metadata>true</send_metadata>
        
        <!-- Enable to skip checking file existence to speed up reads -->
        <skip_access_check>false</skip_access_check>
      </s3_disk_template>
    </disks>
  </storage_configuration>
</clickhouse>
