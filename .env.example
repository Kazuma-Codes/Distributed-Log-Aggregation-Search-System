# -----------------------------------------------------------------------------
# ClickHouse Configuration
# -----------------------------------------------------------------------------
# The host and port for ClickHouse client connections (TCP)
CLICKHOUSE_ADDR=localhost:9000
# ClickHouse HTTP port
CLICKHOUSE_HTTP_PORT=8123
# ClickHouse User
CLICKHOUSE_USER=default
# ClickHouse Password
CLICKHOUSE_PASSWORD=
# ClickHouse Database Name
CLICKHOUSE_DB=logs

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of Kafka brokers
KAFKA_BROKERS=localhost:9092
# The topic where Vector will write logs
KAFKA_TOPIC=logs_topic
# Kafka Consumer Group ID for local consumers
KAFKA_GROUP_ID=log_platform_group

# -----------------------------------------------------------------------------
# MinIO Configuration
# -----------------------------------------------------------------------------
# S3 Endpoint for warm/cold storage
MINIO_ENDPOINT=localhost:9000
# MinIO Access Key
MINIO_ACCESS_KEY=minioadmin
# MinIO Secret Key
MINIO_SECRET_KEY=minioadmin
# Bucket for warm storage
MINIO_WARM_BUCKET=logs-warm
# Bucket for cold storage
MINIO_COLD_BUCKET=logs-cold

# -----------------------------------------------------------------------------
# Go API Configuration
# -----------------------------------------------------------------------------
# Port for the Go HTTP API
API_PORT=8080
# Environment mode: development, production, test
APP_ENV=development
# Log level for the API (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Vector Configuration
# -----------------------------------------------------------------------------
# Vector API port
VECTOR_API_PORT=8686

# -----------------------------------------------------------------------------
# Grafana / Prometheus Configuration
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
