{
  "uid": "log-overview",
  "title": "Log Platform Overview",
  "schemaVersion": 38,
  "style": "dark",
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "uid": "clickhouse",
          "type": "clickhouse"
        },
        "query": "SELECT DISTINCT service FROM default.logs",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "level",
        "type": "query",
        "datasource": {
          "uid": "clickhouse",
          "type": "clickhouse"
        },
        "query": "SELECT DISTINCT level FROM default.logs",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Key Metrics",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Total Logs (last 24h)",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "id": 2,
      "description": "Total logs ingested in the last 24h",
      "targets": [
        {
          "query": "SELECT count() FROM default.logs WHERE timestamp >= now() - INTERVAL 1 DAY"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Current Ingestion Rate (logs/sec)",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "id": 3,
      "description": "Logs ingested per second",
      "targets": [
        {
          "expr": "sum(rate(logs_total[1m]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Rate (%)",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 9,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "id": 4,
      "description": "Percentage of logs with ERROR level",
      "targets": [
        {
          "expr": "sum(rate(log_errors_total[5m])) / sum(rate(logs_total[5m])) * 100"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Services Count",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 14,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "id": 5,
      "description": "Distinct services sending logs",
      "targets": [
        {
          "query": "SELECT count(distinct service) FROM default.logs WHERE $__timeFilter(timestamp)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "P99 Query Latency",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 19,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "id": 6,
      "description": "99th percentile query latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(query_latency_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Time Series",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Log Volume Over Time",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "id": 8,
      "description": "Log volume by service",
      "targets": [
        {
          "query": "SELECT toStartOfMinute(timestamp) as t, service, count() as volume FROM default.logs WHERE $__timeFilter(timestamp) GROUP BY t, service ORDER BY t"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "id": 9,
      "description": "Error rate by service",
      "targets": [
        {
          "expr": "sum(rate(log_errors_total[5m])) by (service) / sum(rate(logs_total[5m])) by (service) * 100"
        }
      ]
    },
    {
      "type": "row",
      "title": "Analysis",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "id": 10
    },
    {
      "type": "table",
      "title": "Top 10 Error Messages",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "id": 11,
      "description": "Most frequent error messages",
      "targets": [
        {
          "query": "SELECT message, count() as occurrences, max(timestamp) as last_seen FROM default.logs WHERE level='ERROR' AND $__timeFilter(timestamp) GROUP BY message ORDER BY occurrences DESC LIMIT 10"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Log Level Distribution",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 6,
        "h": 8
      },
      "id": 12,
      "description": "Distribution of logs by level",
      "targets": [
        {
          "query": "SELECT level, count() as count FROM default.logs WHERE $__timeFilter(timestamp) GROUP BY level"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "HTTP Status Code Distribution",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 18,
        "y": 15,
        "w": 6,
        "h": 8
      },
      "id": 13,
      "description": "Count of HTTP status codes",
      "targets": [
        {
          "query": "SELECT toString(http_status) as status, count() as count FROM default.logs WHERE http_status > 0 AND $__timeFilter(timestamp) GROUP BY status"
        }
      ]
    },
    {
      "type": "row",
      "title": "Heatmap",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "id": 14
    },
    {
      "type": "heatmap",
      "title": "Error Heatmap",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "id": 15,
      "description": "Heatmap of errors per service over time",
      "targets": [
        {
          "query": "SELECT toStartOfMinute(timestamp) as t, service, count() as value FROM default.logs WHERE level='ERROR' AND $__timeFilter(timestamp) GROUP BY t, service ORDER BY t"
        }
      ]
    },
    {
      "type": "row",
      "title": "Live Logs",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "id": 16
    },
    {
      "type": "logs",
      "title": "Recent Logs",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 10
      },
      "id": 17,
      "description": "Recent logs",
      "targets": [
        {
          "query": "SELECT timestamp, level, service, message, trace_id FROM default.logs WHERE $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 100"
        }
      ]
    }
  ]
}