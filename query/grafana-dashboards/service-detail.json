{
  "uid": "service-detail",
  "title": "Service Detail",
  "schemaVersion": 38,
  "style": "dark",
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "uid": "clickhouse",
          "type": "clickhouse"
        },
        "query": "SELECT DISTINCT service FROM default.logs",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Service Stats",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Request Count",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "id": 2,
      "description": "Total requests for the service",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{service=\"$service\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Count",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "id": 3,
      "description": "Total errors",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{service=\"$service\",status=~\"5..\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Rate %",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "id": 4,
      "description": "Error rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"$service\"}[5m])) * 100"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Avg Latency",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "id": 5,
      "description": "Average request latency",
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{service=\"$service\"}[5m])) / sum(rate(http_request_duration_seconds_count{service=\"$service\"}[5m]))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles Over Time",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "id": 7,
      "description": "p50, p90, p95, p99 latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "type": "histogram",
      "title": "Latency Distribution Histogram",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "id": 8,
      "description": "Histogram of latencies",
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le)"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "id": 9
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Code Over Time",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "id": 10,
      "description": "HTTP status codes over time",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\"}[5m])) by (status)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Top Slowest Endpoints",
      "datasource": {
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "id": 11,
      "description": "Slowest endpoints",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Errors",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "id": 12
    },
    {
      "type": "table",
      "title": "Error Messages",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 10
      },
      "id": 13,
      "description": "Recent error messages",
      "targets": [
        {
          "query": "SELECT message, count() as occurrences, max(timestamp) as last_seen FROM default.logs WHERE service='$service' AND level='ERROR' AND $__timeFilter(timestamp) GROUP BY message ORDER BY occurrences DESC LIMIT 20"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Stack Traces",
      "datasource": {
        "uid": "clickhouse"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 10
      },
      "id": 14,
      "description": "Error stack traces",
      "targets": [
        {
          "query": "SELECT timestamp, service, message, stack_trace FROM default.logs WHERE service='$service' AND level='ERROR' AND stack_trace != '' AND $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 50"
        }
      ]
    }
  ]
}